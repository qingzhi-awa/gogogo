<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/circle_run_radius_a"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/circle_radius_a"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="例如: 100" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/circle_run_radius_b"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/circle_radius_b"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="例如: 100 (相同即为正圆)" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/circle_btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/circle_run_cancel"
            android:background="?android:attr/selectableItemBackground" />

        <Button
            android:id="@+id/circle_btn_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/circle_run_start"
            android:textColor="@color/colorAccent"
            android:background="?android:attr/selectableItemBackground" />
    </LinearLayout>
</LinearLayout>
